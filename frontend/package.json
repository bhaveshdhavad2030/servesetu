{
  "name": "servesetu-frontend",
  "version": "1.0.0",
  "description": "Servesetu - Service Marketplace Frontend",
  "type": "module",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
